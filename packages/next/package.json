  "license": "MIT",
  "homepage": "https://github.com/fcjr/shiftapi",
  "repository": {
    "type": "git",
    "url": "https://github.com/fcjr/shiftapi",
    "directory": "packages/next"
  },
  "bugs": {
    "url": "https://github.com/fcjr/shiftapi/issues"
  },
  "type": "module",
