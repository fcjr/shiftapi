{
  "name": "shiftapi",
  "version": "0.0.29",
  "description": "CLI and codegen for shiftapi – fully-typed TypeScript clients from Go servers",
  "author": "Frank Chiarulli Jr. <frank@frankchiarulli.com>",
  "license": "MIT",
  "homepage": "https://github.com/fcjr/shiftapi",
  "repository": {
    "type": "git",
    "url": "https://github.com/fcjr/shiftapi",
    "directory": "packages/shiftapi"
  },
  "bugs": {
    "url": "https://github.com/fcjr/shiftapi/issues"
  },
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./internal": {
      "types": "./dist/internal.d.mts",
      "default": "./dist/internal.mjs"
    }
  },
  "bin": {
    "shiftapi": "./dist/prepare.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "comment-json": "^4.5.1",
    "jiti": "^2.6.1",
    "openapi-typescript": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "tsdown": "^0.21.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
